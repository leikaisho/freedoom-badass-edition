DEATHSCREEN = "You fucked up";
SECRETTEXT =
	"You take a step into the crazy freaky teleporter\n"
	"that opened in the lower floor of the subway.\n"
	"A green color flashes in front of you, and everything\n"
	"suddenly turns dark. After you wake up, you know\n"
	"that you're in for a ride. Let's rock.";
ENDTEXT =
	"After pumping a shit ton of plasma testicles\n"
	"into the mighty Jaw, the Jaw surely dies with\n"
	"an agonizing shriek. You've saved the entire population\n"
	"of Europe. You've done it. You have become\n"
	"the Ultimate Bad*ss. Unfortunately after your\n"
	"celebratory arrival in Romania, your every possesion\n"
	"has been stolen in one millisecond. Too bad*ss.\n"
	"\n"
	"THE BAD*SS END.";
TESTICLETEXT =
	"After nuking everything you press the switch.\n"
	"After that you suddenly die\n"
	"THE BAD*SS END.";

