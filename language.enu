DEATHSCREEN = "Spierdoliłeś";
SECRETTEXT =
	"Wchodzisz do tajemniczego teleportera który\n"
	"otworzył się w dolnym piętrze metra.\n"
	"Odcień zielonego świeci ci się przed oczami, i wszystko\n"
	"się przyciemnia. Po 4 godzinach budzisz się, i już wiesz\n"
	"że czeka na ciebie bolesna przygoda.";
ENDTEXT =
	"Po wystrzeleniu osiemset jąder plazmowych\n"
	"w potężne szczęki, szczęki powoli umierają,\n"
	"głośno wyjąc. Uratowałeś całą populację Europy.\n"
	"Udało ci się. Stałeś się Ostatecznym Twardzielem.\n"
	"Niestety po twojej gratulacyjnej wyczieczce do\n"
	"Rumunii, każda twoja posesja została ukradziona\n"
	"w jedną milisekundę. Ojej.\n"
	"\n"
	"KONIEC.";

TESTICLETEXT =
	"Po wysadzeniu wszystkiego wciskasz dźwignię.\n"
	"Potem umierasz\n"
	"Koniec\n";

